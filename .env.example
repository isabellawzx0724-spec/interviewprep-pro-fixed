OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
AI_PROVIDER=anthropic
AI_ANSWER_ENABLED=true
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
RESUME_AI_PROVIDER=anthropic
DATABASE_URL=
DATABASE_SSL=false

# Turn live site crawling on only after cookie configuration is ready.
ALLOW_LIVE_SCRAPE=false
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_BROWSERS_PATH=0
SCRAPE_TIMEOUT_MS=15000

# Paste the full Cookie request header value from your logged-in browser session.
NOWCODER_COOKIE=
XIAOHONGSHU_COOKIE=

ALLOWED_ORIGIN=http://localhost:5173
NODE_VERSION=22
